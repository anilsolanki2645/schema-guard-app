# ============================================================
# Schema Guard – Environment Configuration Template
# ============================================================
# Copy this file to `.env` and fill in your values.
# NEVER commit the actual `.env` file to version control.
# ============================================================

# Django Settings
SECRET_KEY=your-secret-key-here-generate-with-python-c-from-django.core.management.utils-import-get_random_secret_key
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:8000

# Database Connection (PostgreSQL)
# Option 1: Individual PG* variables
PGHOST=localhost
PGDATABASE=schema_guard
PGUSER=your_db_user
PGPASSWORD=your_db_password
PGSSLMODE=prefer

# Option 2: Full connection string
# DB_CONNECTION_STRING=postgresql://user:password@host:5432/dbname?sslmode=require
# NEON_DB_CONNECTION_STRING=postgresql://user:password@host/dbname?sslmode=require

# Admin Seed Account (used on first startup only)
ADMIN_EMAIL=admin@your-domain.com
ADMIN_PASSWORD=change-this-strong-password

# Email Alerting (SMTP)
EMAIL_ENABLED=true
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=your-email@gmail.com
EMAIL_TO=alerts@your-domain.com

# Snowflake Connection (optional)
# SNOWFLAKE_DB_CONNECTION_STRING=snowflake://user:pass@account/database/schema?warehouse=WH&role=ROLE

# WhatsApp Alerting (CallMeBot)
# WHATSAPP_API_KEY=your_callmebot_api_key
# WHATSAPP_PHONE=+919876543210

# Slack Alerting
# WEBHOOK_URL=https://hooks.slack.com/services/YOUR_WORKSPACE/YOUR_CHANNEL/YOUR_TOKEN

# Session Settings
# SESSION_COOKIE_AGE=86400

# ============================================================
# Render.com Deployment Notes
# ============================================================
# On Render, set these environment variables in the dashboard:
#   SECRET_KEY          → auto-generated via render.yaml
#   DEBUG               → false  (NEVER true in production)
#   ALLOWED_HOSTS       → .onrender.com
#   CSRF_TRUSTED_ORIGINS→ https://your-app-name.onrender.com
#   DB_CONNECTION_STRING→ auto-linked from Render PostgreSQL
#   EMAIL_USER          → your Gmail address
#   EMAIL_PASSWORD      → Gmail App Password (not your login password)
#   EMAIL_FROM          → same as EMAIL_USER
#
# Render auto-sets RENDER_EXTERNAL_HOSTNAME which is picked up
# by settings.py to configure ALLOWED_HOSTS and CSRF origins.
# ============================================================
